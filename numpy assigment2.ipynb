# ==========================================
# STEP 1: NUMPY LIBRARY KO IMPORT KARNA
# ==========================================
# 'import' ka matlab hai hum numpy ko apne program mein bula rahe hain.
# 'as np' ka matlab hai ki ab se hum poore code mein numpy ko sirf 'np' bolenge.

import numpy as np 

# ==========================================
# QUESTION 1: 1D ARRAY (EK LINE WALE NUMBERS)
# ==========================================

# a. 1 se 20 tak ka array banana
# np.arange(1, 21) ka matlab hai 1 se shuru karo aur 21 se pehle (yani 20 par) khatam karo.
arr1 = np.arange(1, 21)
print("1. Hamara 1D Array:\n", arr1)

# Basic math calculations
print("Total Jod (Sum):", np.sum(arr1))
print("Average (Mean):", np.mean(arr1))
print("Beech wala number (Median):", np.median(arr1))
print("Standard Deviation (Numbers ka phelao):", np.std(arr1))

# b. 10 se bade numbers ki position (Index) dhundna
# np.where command humein batati hai ki shartein (conditions) kahan poori ho rahi hain.
indices = np.where(arr1 > 10)
print("10 se bade numbers in positions par hain:", indices[0])


# ==========================================
# QUESTION 2: 2D ARRAY (TABLE JAISA)
# ==========================================

# a. 1 se 16 tak ke numbers ko 4 rows aur 4 columns mein sajana
# reshape(4, 4) ka matlab hai table ka size 4x4 kar do.
arr2d = np.arange(1, 17).reshape(4, 4)
print("\n2. Hamara 4x4 Array:\n", arr2d)

# b. Transpose (Table ko ghuma dena)
# Isse khadi lines (columns) aadi lines (rows) ban jati hain.
print("Transpose (Rows ko Columns banana):\n", arr2d.T)

# c. Row-wise aur Column-wise Jod
# axis=1 ka matlab hai left to right jodna (Row)
# axis=0 ka matlab hai upar se niche jodna (Column)
print("Har Row ka total:", np.sum(arr2d, axis=1))
print("Har Column ka total:", np.sum(arr2d, axis=0))


# ==========================================
# QUESTION 3: RANDOM ARRAYS AUR MATHS
# ==========================================

# Do 3x3 ke random table banana (1 se 20 ke beech koi bhi number)
A = np.random.randint(1, 21, (3, 3))
B = np.random.randint(1, 21, (3, 3))

print("\n3. Random Array A:\n", A)
print("Random Array B:\n", B)

# a. Amne-samne wale numbers ka calculation (Element-wise)
print("Dono ka Jod (A+B):\n", A + B)
print("Dono ka Ghatana (A-B):\n", A - B)
print("Dono ka Guna (A*B):\n", A * B)

# b. Dot Product (Matrix Multiplication ka khas rule)
dot_product = np.dot(A, B)
print("Dot Product (A . B):\n", dot_product)


# ==========================================
# QUESTION 4: RESHAPE AUR SLICING (TUKDE KARNA)
# ==========================================

# 12 numbers ka 1D array banana aur use 3x4 (3 rows, 4 columns) mein badalna
arr_slice = np.arange(1, 13).reshape(3, 4)
print("\n4. 3x4 Array Slicing ke liye:\n", arr_slice)

# Slicing: [Rows , Columns]
# [0:2] matlab index 0 aur 1 wali rows (pehli do)
# [2:4] matlab index 2 aur 3 wale columns (aakhri do)
result = arr_slice[0:2, 2:4]
print("Kata hua hissa (Pehli 2 rows aur Aakhri 2 columns):\n", result)